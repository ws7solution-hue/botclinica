{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/app/index.html"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    },
    {
      "source": "/checkout/:path*",
      "destination": "/checkout.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/crm",
      "destination": "/crm.html"
    },
    {
      "source": "/crm/:path*",
      "destination": "/crm.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}