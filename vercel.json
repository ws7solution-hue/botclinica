{
  "rewrites": [
    { "source": "/api/:path*",        "destination": "/api/:path*" },
    { "source": "/app/assets/:path*", "destination": "/app/assets/:path*" },
    { "source": "/app",               "destination": "/app/index.html" },
    { "source": "/app/:path*",        "destination": "/app/index.html" },
    { "source": "/:path*",            "destination": "/index.html" }
  ]
}