{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/app/assets/:path*", "destination": "/dist/assets/:path*" },
    { "source": "/app/:path*", "destination": "/dist/index.html" },
    { "source": "/app", "destination": "/dist/index.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/crm", "destination": "/crm.html" },
    { "source": "/", "destination": "/landing.html" }
  ]
}
